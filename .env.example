# JobCodex Configuration

# Database
DATABASE_URL=sqlite+aiosqlite:///./jobcodex.db

# Security
SECRET_KEY=change-this-to-a-secure-random-string

# Personal mode
PERSONAL_USER_EMAIL=personal@jobcodex.local

# OpenAI Configuration (optional - without this, template-based generation is used)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=500

# Server
DEBUG=false
